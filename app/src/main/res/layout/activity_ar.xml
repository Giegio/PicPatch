<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout fullscreen per l'esperienza AR.
  Il ArSceneView occupa tutto lo schermo; sopra ci sono solo
  gli overlay minimi richiesti: mirino + pulsante chiudi + status bar.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ar_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- ── AR Scene View (fullscreen) ── -->
    <io.github.sceneview.ar.ArSceneView
        android:id="@+id/ar_scene_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Mirino di tracking (crosshair) ── -->
    <ImageView
        android:id="@+id/iv_reticle"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_reticle"
        android:contentDescription="@null"
        android:alpha="0.85"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Label di stato (GPS/marker istruzioni) ── -->
    <TextView
        android:id="@+id/tv_ar_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_ar_label"
        android:fontFamily="@font/inter_semibold"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btn_ar_unlock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Avvicinati al luogo…"
        tools:visibility="visible"
        tools:ignore="MissingFontFamily" />

    <!-- ── Pulsante chiudi (in alto a destra) ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_ar_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="@string/btn_close"
        android:src="@drawable/ic_close"
        app:backgroundTint="#CC1A1A2E"
        app:fabSize="mini"
        app:tint="@color/color_on_surface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Pulsante "Sblocca" (appare quando condizioni soddisfatte) ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ar_unlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="🎉 Sblocca sorpresa"
        android:textAllCaps="false"
        android:visibility="gone"
        app:backgroundTint="@color/color_secondary"
        app:cornerRadius="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
