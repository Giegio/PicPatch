<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ───── Permissions ───── -->

    <!-- Camera: obbligatoria per ARCore -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- GPS per card di tipo GPS/HYBRID -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ARCore hardware feature
         required="true" → solo device con ARCore supportato.
         Cambia in "false" se vuoi distribuire anche su device senza AR
         (l'ARActivity mostrerà un fallback). -->
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="true" />

    <!-- Camera feature esplicita -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <application
        android:name=".PicPatchApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PicPatch">

        <!-- Metadato ARCore obbligatorio -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="required"
            tools:replace="android:value" />

        <!-- ───── Activities ───── -->

        <activity
            android:name=".ui.gallery.GalleryActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.ar.ARActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.PicPatch.AR" />

        <activity
            android:name=".ui.gps.GPSActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.PicPatch" />

        <receiver
            android:name=".notification.NotificationReceiver"
            android:exported="false" />

    </application>

</manifest>
